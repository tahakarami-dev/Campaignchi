              "settings": {
                "editor": "<p style=\"font-family:Vazirmatn,Tahoma,sans-serif;font-size:16px;line-height:1.8;color:#6B7280;text-align:center;max-width:520px;margin:0 auto 48px;\">هر قالب با شخصیت متفاوت — از انرژی Flux تا سادگی Minimal انتخاب کنید.</p>",
                "align": "center"
