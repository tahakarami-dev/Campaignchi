x;margin-bottom:12px;\">\n        <div style=\"width:48px;height:48px;border-radius:10px;background:rgba(255,255,255,0.2);margin-bottom:10px;\"></div>\n        <div style=\"font-size:14px;font-weight:700;color:#fff;\">ساعت هوشمند Apple</div>\n        <div style=\"font-size:11px;color:rgba(255,255,255,0.7);margin-bottom:8px;\">تکنولوژی</div>\n        <div style=\"font-size:17px;font-weight:800;color:#fff;\">۴,۵۰۰,۰۰۰ ت</div>\n      </div>\n      <div style=\"display:flex;gap:6px;\">\n        <div style=\"background:rgba(255,255,255,0.15);backdrop-filter:blur(10px);border-radius:6px;padding:4px 8px;text-align:center;flex:1;\">\n          <div style=\"font-size:14px;font-weight:700;color:#fff;\">۰۱</div>\n          <div style=\"font-size:9px;color:rgba(255,255,255,0.6);\">روز</div>\n        </div>\n        <div style=\"background:rgba(255,255,255,0.15);backdrop-filter:blur(10px);border-radius:6px;padding:4px 8px;text-align:center;flex:1;\">\n          <div style=\"font-size:14px;font-weight:700;color:#fff;\">۲۳</div>\n          <div style=\"font-size:9px;color:rgba(255,255,255,0.6);\">ساعت</div>\n        </div>\n        <div style=\"background:rgba(255,255,255,0.15);backdrop-filter:blur(10px);border-radius:6px;padding:4px 8px;text-align:center;flex:1;\">\n          <div style=\"font-size:14px;font-weight:700;color:#fff;\">۵۹</div>\n          <div style=\"font-size:9px;color:rgba(255,255,255,0.6);\">دقیقه</div>\n        </div>\n      </div>\n    </div>\n  </div>\n  <div style=\"background:#2D1B69;padding:12px 16px;\">\n    <div style=\"display:flex;align-items:center;justify-content:space-between;\">\n      <span style=\"font-size:13px;font-weight:700;color:#A78BFF;\">Glass</span>\n      <span style=\"font-size:11px;color:rgba(255,255,255,0.3);\">گلاسمورفیسم — لوکس</span>\n    </div>\n  </div>\n</div>\n\n<!-- BOLD -->\n<div style=\"border-radius:20px;overflow:hidden;box-shadow:0 12px 30px rgba(255,107,53,0.2);\">\n  <div style=\"background:#111827;padding:20px;min-heigh